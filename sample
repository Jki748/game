
define jki = Character('jki', color="#c8ffc8")
define me = Character(_("me"), color="#c8c8ff")


label start:

    scene bg fon

    show jki2

    jki "Доров, чувак"
    jki "Хочешь расскажу тебе короткую, но грустную историю?"

    me "..."

    menu:

        "Я решил сказать..."

        "Да":

            jump yes

        "Нет":

            jump no


label yes:

    show jki2

    me "Давай"
    jki "Слушай..."
    jki "А ты первый, кто согласился"
    jki "В этом и есть вся история...
    Никто не хочет меня слушать мои истории из жизни"
    "Я внимательно вглядывался в ее глаза. Она пристально смотрела на меня"
    jki "А еще у меня кошка умерла. Вот тебе вторая история"
    "Я не знал, что ответить. Поэтому использовал фразу на все случаи жизни:"
    me "Мне жаль"
    "Мне стало немного грустно"
    " 'Не могу подобрать нужных слов. Я в этом не эксперт. Может, ей поможет нечто другое?..' "
    me "Иди сюда"

    hide jki2
    show jki3

    "Она посмотрела на меня удивленными глазами, когда я раскинул руки в разные стороны"
    jki "Она сделала шаг ко мне"
    "Я подошел к ней и крепко-крепко обнял"

    hide jki3
    show jki2

    jki "Ладно, не буду пока тебя убивать"


    "{b}Хороший конец{/b}."

    return







label no:

    show jki2

    me "Не, спасибо"
    jki "Тогда пошел на хуй"

    hide jki2
    show jki4

    "Она выстрелила мне в плечо"

    me "БЛЯТЬ"

    "Я стиснул зубы от сильной боли"

    jki "А теперь слушай историю..."

    "Она начала говорить"

    "В все в миг потемнело, и я почувствовал, как теряю сознание"

    "{b}Плохой конец{/b}."

    return
